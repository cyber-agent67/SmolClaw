# OpenAI API Key
OPENAI_API_KEY=sk-...

# Anthropic API Key
ANTHROPIC_API_KEY=sk-...

# Hugging Face Token (required for smolhand/smoleyes)
HF_TOKEN=hf_your_token_here
HUGGINGFACE_TOKEN=hf_your_token_here

# Vision Model (optional)
# VISION_MODEL=gpt-4-vision-preview

# Gateway Configuration (optional)
# GATEWAY_HOST=127.0.0.1
# GATEWAY_PORT=8765
# GATEWAY_API_PORT=8766

# Smolhand Configuration (optional)
# SMOLHAND_MODEL=Qwen/Qwen2.5-7B-Instruct
# SMOLHAND_BASE_URL=https://router.huggingface.co/v1
